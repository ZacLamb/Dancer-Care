# PostgreSQL connection string (Railway auto-injects this when you add a Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/careconnect"

# 32+ character random string used to sign session JWTs
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# Public base URL of the app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
